{
  "manifest_version": 3,
  "name": "LinkVault – Smart Resource Manager",
  "version": "1.0.0",
  "description": "Save links, PDFs & docs in organized categories with AI-powered summaries",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkVault"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
